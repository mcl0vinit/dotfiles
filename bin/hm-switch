#!/usr/bin/env bash
set -euo pipefail

dotfiles_dir="${DOTFILES_DIR:-$HOME/.dotfiles}"
os="$(uname -s)"
arch="$(uname -m)"

case "$os:$arch" in
  Darwin:arm64)
    profile="portable-darwin"
    export DOTFILES_SYSTEM="aarch64-darwin"
    ;;
  Darwin:x86_64)
    profile="portable-darwin"
    export DOTFILES_SYSTEM="x86_64-darwin"
    ;;
  Linux:x86_64)
    profile="portable-linux"
    export DOTFILES_SYSTEM="x86_64-linux"
    ;;
  Linux:aarch64|Linux:arm64)
    profile="portable-linux-arm"
    export DOTFILES_SYSTEM="aarch64-linux"
    ;;
  *)
    printf 'Unsupported platform: %s %s\n' "$os" "$arch" >&2
    exit 1
    ;;
esac

export DOTFILES_DIR="$dotfiles_dir"
export DOTFILES_USER="${DOTFILES_USER:-${USER:-}}"
export DOTFILES_HOME="${DOTFILES_HOME:-$HOME}"
export NIX_CONFIG="${NIX_CONFIG:+$NIX_CONFIG
}experimental-features = nix-command flakes"

if command -v home-manager >/dev/null 2>&1; then
  exec home-manager switch --impure --flake "$dotfiles_dir#$profile" "$@"
fi

exec nix run github:nix-community/home-manager -- switch --impure --flake "$dotfiles_dir#$profile" "$@"
